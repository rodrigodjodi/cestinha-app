rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAnotador() {
      return request.auth != null && request.auth.uid == resource.data.anotadorId;
    }
    function grupoDoc(grupoId) {
      return get(/databases/$(database)/documents/grupos/$(grupoId));
    }
    function isAdminDoGrupo(grupoId) {
      return request.auth != null
        && request.auth.uid in grupoDoc(grupoId).data.adminUids;
    }
    function alteraApenasTimes() {
    return request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly(['times']);
}

    match /convites/{convite} {
      allow get:if request.auth != null;
      allow list: if false;
    }
    match /dias/{dia} {
      allow read: if request.auth != null;
      allow update: if isAdminDoGrupo(resource.data.grupoId)
        && request.resource.data.grupoId == resource.data.grupoId
        && alteraApenasTimes();
    }
    match /grupos/{grupo} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.usuarios;
    }
    match /jogadores/{jodagor} {
      allow read: if request.auth != null;
    }
    match /jogos/{jogo} {
      allow read: if request.auth != null;
      allow update: if isAnotador();
    }
    match /presencas/{presenca} {
      allow read: if request.auth != null;
    }
    match /jogadas/{jogada} {
      allow read: if request.auth != null;
    }
  }
}
