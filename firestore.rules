rules_version = '2';
function isAnotador() {
  return request.auth.uid == resource.data.anotadorId;
}
service cloud.firestore {
  match /databases/{database}/documents {
    match /convites/{convite} {
      allow get:if request.auth != null;
      allow list: if false;
    }
    match /dias/{dia} {
      allow read: if request.auth != null;
    }
    match /grupos/{grupo} {
      allow read: if request.auth.uid in resource.data.usuarios;
    }
    match /jogadores/{jodagor} {
      allow read: if request.auth != null;
    }
    match /jogos/{jogo} {
      allow read: if request.auth != null;
      allow update: if isAnotador();
    }
    match /presencas/{presenca} {
      allow read: if request.auth != null;
    }
  }
}